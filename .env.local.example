# Email Configuration for NodeMailer
# 
# For Gmail:
# 1. Go to your Google Account settings
# 2. Enable 2-Step Verification
# 3. Go to Security > 2-Step Verification > App passwords
# 4. Generate an app password and use it below
#
# IMPORTANT: Never commit this file with real credentials!

# Your email address (where you'll receive contact form messages)
EMAIL_USER=your-email@gmail.com

# Your email app password (NOT your regular Gmail password)
EMAIL_PASSWORD=your-app-password-here

# Alternative SMTP Configuration (if not using Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
